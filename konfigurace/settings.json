{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "mcp__pal-clink__*",
      "mcp__sequentialthinking__*",
      "mcp__reddit__*",
      "mcp__magic__*",
      "mcp__plugin_serena_serena__*",
      "mcp__zotero__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/marioboss/diplomova-prace/.claude/hooks/bash_hook.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/marioboss/diplomova-prace/.claude/hooks/file_protection.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/marioboss/diplomova-prace/.claude/hooks/stop_hook.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
